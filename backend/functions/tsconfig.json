{
  "compilerOptions": {
    "module": "commonjs",        
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "target": "es2020",          
    "esModuleInterop": true,
    "skipLibCheck": true,        
    "forceConsistentCasingInFileNames": true,
    "types": ["jest", "node"]
  },
  "compileOnSave": true,
  "include": ["src"],
  "exclude": ["node_modules"]
}
